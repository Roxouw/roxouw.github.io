{
  "name": "roxouw.github.io",
  "version": "1.0.0",
  "description": "Site profissional para apresentação de serviços de desenvolvimento web, com foco em captação de clientes para sites, landing pages e sistemas web.",
  "scripts": {
    "check:links": "node scripts/check-html-links.js",
    "check": "npm run lint && npm run check:links",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "report:pages": "node scripts/generate-obsidian-pages-report.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Roxouw/roxouw.github.io.git"
  },
  "author": "Rosso Labs",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Roxouw/roxouw.github.io/issues"
  },
  "homepage": "https://roxouw.github.io",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsonlint": "^1.6.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,jsx,tsx,json,md,css,html}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,jsx,tsx}": [
      "eslint --fix"
    ]
  }
}
